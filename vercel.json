{
  "rewrites": [
    { "source": "/",            "destination": "/login.html" },
    { "source": "/login",       "destination": "/login.html" },
    { "source": "/definir-senha","destination": "/definir-senha.html" },
    { "source": "/aluno",       "destination": "/aluno/perfil.html" },
    { "source": "/admin",       "destination": "/admin/alunos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
